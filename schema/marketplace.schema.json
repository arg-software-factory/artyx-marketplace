{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://artyx.ai/schemas/marketplace.schema.json",
  "title": "Artyx marketplace index",
  "description": "Thin curated index. Each entry is a pointer to a self-describing plugin; array order is the curation order. All storefront metadata lives in the plugin's own manifest, never here.",
  "type": "object",
  "required": ["$schema", "name", "owner", "plugins"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "const": "artyx-marketplace"
    },
    "description": {
      "type": "string"
    },
    "owner": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "source"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "source": {
            "type": "string",
            "pattern": "^\\./plugins/[a-z0-9]+(?:-[a-z0-9]+)*$"
          }
        }
      }
    }
  }
}
