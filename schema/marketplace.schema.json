{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://artyx.ai/schemas/marketplace.schema.json",
  "type": "object",
  "required": ["$schema", "name", "description", "owner", "plugins"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "const": "artyx-marketplace"
    },
    "description": {
      "type": "string"
    },
    "owner": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "description", "author", "category", "icon", "source"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "description": {
            "type": "string"
          },
          "author": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              },
              "url": {
                "type": "string",
                "format": "uri"
              }
            }
          },
          "category": {
            "type": "string",
            "enum": ["creative", "dev", "games", "productivity", "other"]
          },
          "icon": {
            "type": "string"
          },
          "source": {
            "type": "string",
            "pattern": "^\\./plugins/[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "homepage": {
            "type": "string",
            "format": "uri"
          },
          "experimental": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
