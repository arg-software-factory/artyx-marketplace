{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://artyx.ai/schemas/marketplace-v2.schema.json",
  "type": "object",
  "required": ["$schema", "schemaVersion", "name", "description", "owner", "plugins"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 2 },
    "name": { "const": "artyx-marketplace" },
    "description": { "type": "string" },
    "owner": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "version", "description", "category", "icon", "archive", "compatibility"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][0-9A-Za-z.-]+)?$" },
          "description": { "type": "string" },
          "category": { "enum": ["creative", "dev", "games", "productivity", "other"] },
          "icon": { "type": "string" },
          "homepage": { "type": "string", "format": "uri" },
          "experimental": { "type": "boolean" },
          "archive": {
            "type": "object",
            "required": ["url", "sha256", "sizeBytes"],
            "additionalProperties": false,
            "properties": {
              "url": { "type": "string", "format": "uri" },
              "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "sizeBytes": { "type": "integer", "minimum": 1 }
            }
          },
          "compatibility": {
            "type": "object",
            "required": ["artyx"],
            "additionalProperties": false,
            "properties": {
              "artyx": { "type": "string" },
              "platforms": {
                "type": "array",
                "items": { "enum": ["darwin", "win32", "linux"] },
                "uniqueItems": true
              }
            }
          }
        }
      }
    }
  }
}
