{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://artyx.ai/schemas/plugin.schema.json",
  "title": "Artyx plugin manifest",
  "description": "Self-describing plugin bundle. Lives at plugins/<name>/.artyx-plugin/plugin.json and follows the OpenAI plugin manifest shape with a minimal Artyx extension.",
  "type": "object",
  "required": ["name", "version", "description", "author", "interface"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "description": {
      "type": "string",
      "description": "One-line summary used for search/indexing. The rich storefront copy lives under interface."
    },
    "author": {
      "oneOf": [
        {
          "type": "object",
          "required": ["name"],
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string" },
            "url": { "type": "string", "format": "uri" }
          }
        },
        { "type": "string" }
      ]
    },
    "homepage": {
      "type": "string",
      "format": "uri"
    },
    "repository": {
      "type": "string",
      "format": "uri"
    },
    "license": {
      "type": "string"
    },
    "keywords": {
      "type": "array",
      "items": { "type": "string" }
    },
    "skills": { "type": "string" },
    "agents": { "type": "string" },
    "commands": { "type": "string" },
    "hooks": { "type": "string" },
    "apps": { "type": "string" },
    "mcpServers": { "type": "string" },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "artyx": {
          "type": "string",
          "pattern": "^>=\\d+\\.\\d+\\.\\d+$"
        },
        "platforms": {
          "type": "array",
          "items": { "type": "string", "enum": ["darwin", "win32", "linux"] },
          "uniqueItems": true
        }
      }
    },
    "interface": {
      "type": "object",
      "description": "The storefront card. Single source of truth for how the plugin renders in Settings -> Marketplace.",
      "required": ["displayName", "shortDescription", "category"],
      "additionalProperties": false,
      "properties": {
        "displayName": { "type": "string" },
        "shortDescription": { "type": "string" },
        "longDescription": { "type": "string" },
        "developerName": { "type": "string" },
        "category": { "type": "string", "minLength": 1 },
        "capabilities": {
          "type": "array",
          "items": { "type": "string", "enum": ["Interactive", "Read", "Write"] },
          "uniqueItems": true
        },
        "brandColor": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "websiteURL": { "type": "string", "format": "uri" },
        "privacyPolicyURL": { "type": "string", "format": "uri" },
        "termsOfServiceURL": { "type": "string", "format": "uri" },
        "composerIcon": { "type": "string" },
        "logo": {
          "type": "string",
          "description": "Optional relative path to a PNG/SVG in ./assets/."
        },
        "defaultPrompt": {
          "type": "array",
          "items": { "type": "string" }
        },
        "screenshots": {
          "type": "array",
          "items": { "type": "string" }
        },
        "experimental": {
          "type": "boolean"
        }
      }
    },
    "artyx": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "companion": {
          "type": "object",
          "required": ["title", "steps"],
          "additionalProperties": false,
          "properties": {
            "title": { "type": "string" },
            "summary": { "type": "string" },
            "steps": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "docsUrl": { "type": "string", "format": "uri" },
            "downloadUrl": { "type": "string", "format": "uri" },
            "prerequisites": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    }
  }
}
