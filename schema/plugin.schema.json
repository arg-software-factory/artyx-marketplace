{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://artyx.ai/schemas/plugin.schema.json",
  "type": "object",
  "required": ["name", "version", "description", "author"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "description": {
      "type": "string"
    },
    "author": {
      "oneOf": [
        {
          "type": "object",
          "required": ["name"],
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            },
            "url": {
              "type": "string",
              "format": "uri"
            }
          }
        },
        {
          "type": "string"
        }
      ]
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "homepage": {
      "type": "string",
      "format": "uri"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "icon": {
      "type": "string"
    },
    "license": {
      "type": "string"
    },
    "components": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "skills": {
          "type": "string"
        },
        "agents": {
          "type": "string"
        },
        "mcp": {
          "type": "string"
        },
        "assets": {
          "type": "string"
        }
      }
    },
    "companion": {
      "type": "object",
      "required": ["title", "steps"],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "docsUrl": {
          "type": "string",
          "format": "uri"
        },
        "downloadUrl": {
          "type": "string",
          "format": "uri"
        },
        "prerequisites": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
