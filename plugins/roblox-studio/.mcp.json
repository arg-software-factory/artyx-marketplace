{
  "mcpServers": {
    "studio": {
      "platform": {
        "darwin": {
          "command": "/Applications/RobloxStudio.app/Contents/MacOS/StudioMCP"
        },
        "win32": {
          "command": "cmd.exe",
          "args": ["/d", "/s", "/c", "${LOCALAPPDATA}\\Roblox\\mcp.bat"]
        }
      }
    }
  }
}
